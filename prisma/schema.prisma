generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("STAFF")
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores            Store[]
  orders            Order[]
  chats             Chat[]
  notifications     Notification[]
  reports           Report[]
  products          Product[]
  shopeeConnections ShopeeConnection[]

  @@index([email])
  @@index([role])
}

model Store {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  shopeeId       String   @unique
  apiKey         String
  apiSecret      String
  status         String   @default("ACTIVE")
  rating         Float    @default(0)
  totalOrders    Int      @default(0)
  totalRevenue   Float    @default(0)
  totalProducts  Int      @default(0)
  totalChats     Int      @default(0)
  totalVisitors  Int      @default(0)
  conversionRate Float    @default(0)
  lastSyncAt     DateTime?
  isConnected    Boolean  @default(false)
  shopeeShopId   Int?     @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders            Order[]
  products          Product[]
  chats             Chat[]
  notifications     Notification[]
  shopeeConnections ShopeeConnection[]

  @@index([userId])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderNumber   String
  buyerName     String
  buyerPhone    String?
  buyerAddress  String?
  totalAmount   Float
  status        String
  paymentStatus String      @default("PENDING")
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  @@unique([storeId, orderNumber])
  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

model Product {
  id         String   @id @default(cuid())
  userId     String
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopeeId   String
  name       String
  sku        String
  description String?
  price      Float
  stock      Int
  sold       Int      @default(0)
  images     Json     @default("[]")
  status     String   @default("ACTIVE")
  isLowStock Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orderItems OrderItem[]

  @@unique([storeId, sku])
  @@index([userId])
  @@index([storeId])
  @@index([status])
}

model Chat {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  buyerName   String
  buyerAvatar String?
  productName String?
  message     String
  status      String   @default("UNREAD")
  isReplied   Boolean  @default(false)
  reply       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  repliedAt   DateTime?

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([storeId])
  @@index([isRead])
  @@index([createdAt])
}

model Report {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  type           String
  storeIds       String[] @default([])
  startDate      DateTime
  endDate        DateTime
  totalRevenue   Float?
  totalOrders    Int?
  totalProducts  Int?
  totalChats     Int?
  conversionRate Float?
  data           Json?
  fileUrl        String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ── Shopee OAuth Models ──

model ShopeeConnection {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopId        Int
  shopName      String
  accessToken   String
  refreshToken  String
  accessTokenExpiresAt   DateTime
  refreshTokenExpiresAt  DateTime
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId])
  @@unique([shopId])
  @@index([userId])
}
