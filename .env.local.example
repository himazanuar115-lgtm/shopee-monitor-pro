# Database (Postgres example)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_to_a_secure_random_value

# NextAuth providers (example: GitHub)
GITHUB_ID=
GITHUB_SECRET=

# Shopee API credentials
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URI=http://localhost:3000/api/shopee/callback

# Other optional settings
# TOKEN_REFRESH_THRESHOLD_SECONDS=300
# NODE_ENV=development
